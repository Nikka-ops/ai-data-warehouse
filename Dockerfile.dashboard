FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir \
    clickhouse-connect \
    openai \
    langchain==0.3.25 \
    langchain-openai==0.3.16 \
    chromadb \
    sentence-transformers \
    streamlit \
    plotly \
    pandas \
    tabulate \
    python-dotenv \
    tenacity
COPY . .
CMD ["streamlit", "run", "app/dashboard.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
