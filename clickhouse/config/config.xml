<clickhouse>
    <!-- 查询复杂度限制（生产安全配置）-->
    <max_query_size>1073741824</max_query_size>
    <max_ast_depth>1000</max_ast_depth>
    <max_expanded_ast_elements>500000</max_expanded_ast_elements>

    <!-- 内存限制 -->
    <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>
    <max_memory_usage>8589934592</max_memory_usage>  <!-- 8GB 单查询上限 -->

    <!-- 连接数限制 -->
    <max_connections>4096</max_connections>
    <max_concurrent_queries>100</max_concurrent_queries>

    <!-- 日志配置 -->
    <logger>
        <level>warning</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>500M</size>
        <count>5</count>
    </logger>

    <!-- 慢查询日志（超过5秒记录）-->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>

    <!-- 压缩：LZ4 默认，大块数据用 ZSTD -->
    <compression>
        <case>
            <method>lz4</method>
        </case>
    </compression>

    <!-- 分布式 DDL（单节点关闭）-->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
