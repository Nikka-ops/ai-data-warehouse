# ============================================================
# 实时 AI 数仓 — 环境变量模板
# 使用方式：cp .env.example .env  然后填入真实值
# 生产环境必须修改所有标注 "生产必改" 的字段！
# ============================================================

# ── LLM（必填）────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── ClickHouse（生产环境修改密码）──────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=change-me-in-production   # 生产必改！

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDERS_TOPIC=orders_stream
KAFKA_PAYMENTS_TOPIC=payments_stream
KAFKA_FLINK_STATS_TOPIC=flink.minute_stats
KAFKA_FLINK_DWD_TOPIC=flink.realtime_dwd
KAFKA_FLINK_ALERTS_TOPIC=flink.alerts

# ── Superset BI（生产环境修改 SECRET_KEY 和密码）──────────────
SUPERSET_SECRET_KEY=change-me-to-random-64-char-string   # 生产必改！
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=change-me-in-production          # 生产必改！

# ── Grafana 监控（生产环境修改密码）───────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production           # 生产必改！

# ── AI 超参（有默认值，可不填）──────────────────────────────
NL2SQL_TEMPERATURE=0.1
INSIGHT_TEMPERATURE=0.7
RAG_TEMPERATURE=0.3
AGENT_TEMPERATURE=0.3
RAG_TOP_K=3
SCHEMA_CACHE_TTL=300

# ── 日志级别（开发DEBUG，生产WARNING）────────────────────────
LOG_LEVEL=INFO
