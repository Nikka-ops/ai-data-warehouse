# ============================================================
# 实时 AI 数仓配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ── LLM ──────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── ClickHouse ────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=change-me-in-production

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ORDERS_TOPIC=orders_stream
KAFKA_PAYMENTS_TOPIC=payments_stream
KAFKA_FLINK_STATS_TOPIC=flink.minute_stats
KAFKA_FLINK_DWD_TOPIC=flink.realtime_dwd
KAFKA_FLINK_ALERTS_TOPIC=flink.alerts

# ── AI 超参（有默认值，可不填）──────────────────────────────
NL2SQL_TEMPERATURE=0.1
INSIGHT_TEMPERATURE=0.7
RAG_TEMPERATURE=0.3
AGENT_TEMPERATURE=0.3
RAG_TOP_K=3
SCHEMA_CACHE_TTL=300

# ── 日志级别 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
